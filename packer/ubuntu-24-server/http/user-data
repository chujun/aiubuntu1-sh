#cloud-config
# Ubuntu 24.04 Server Autoinstall (Subiquity) 配置文件
# 用于 Packer 无人值守安装

autoinstall:
  version: 1

  # --------------------------------------------------------
  # 身份配置 - 用户/主机信息
  # --------------------------------------------------------
  identity:
    hostname: ubuntu-server
    username: ubuntu
    password: $6$7Q6faMv8r3uqGix9$AlCxRApouBwiyqjL6JuBVIHHvKUjDHriPbM.k5zSSA3yTJTBmNnbcKC4k6DNh1O/hpuBiPPao4cqoHkHCBVDN/

  # --------------------------------------------------------
  # 存储分区配置 - 使用 LVM 自动分区
  # --------------------------------------------------------
  storage:
    layout:
      name: lvm

  # --------------------------------------------------------
  # SSH 配置
  # --------------------------------------------------------
  ssh:
    install-server: true
    allow-pw: true

  # --------------------------------------------------------
  # 网络配置 - DHCP 自动获取 IP
  # --------------------------------------------------------
  network:
    version: 2
    ethernets:
      ens33:
        dhcp4: true
        optional: true

  # --------------------------------------------------------
  # APT 配置
  # --------------------------------------------------------
  package-update: true
  package-upgrade: true
  packages:
    - openssh-server
    - cloud-init
    - curl
    - wget

  # --------------------------------------------------------
  # 晚期命令 - 安装完成后执行
  # --------------------------------------------------------
  late-commands:
    - sleep 5
    - curtin in-target --target=/target -- systemctl enable ssh
    - curtin in-target --target=/target -- cloud-init clean --logs

  # --------------------------------------------------------
  # 错误处理
  # --------------------------------------------------------
  error-commands:
    - echo "Installation failed"
    - cat /var/log/syslog
